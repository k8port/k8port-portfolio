{
	"formatOnSave": true,
	"editor": {
		"formatOnSave": true,
		"defaultFormatter": "prettier"
	},
	"vim": {
		"enabled": true,
		"normalModeKeyBindings": [
			{
				"before": [ "g", "q" ],
				"after": [],
				"commands": [
					{
						"command": "editor.action.formatDocument"
					}
				]
			},
			{
				"before": [ "=", "G" ],
				"after": [],
				"commands": [
					{
						"command": "editor.action.formatDocument"
					}
				]
			}
		],
		"normalModeKeyBindingsNonRecursive": [
			{
				"before": [ "g", "g", "=", "G" ],
				"after": [],
				"commands": [
					{
						"command": "editor.action.formatDocument"
					}
				]
			}
		],
		"useSystemClipboard": true
	},
	"prettier": {
		"singleQuote": true,
		"tabWidth": 2,
		"printWidth": 100,
		"trailingComma": "es5"
	},
	"commands": {
		"custom": {
			"formatFile": {
				"script": ".vscode/format.js",
				"functionName": "formatDocument",
				"keybinding": "ctrl+alt+p"
			}
		}
	}
}
