    "scripts": {
        "dev": "NODE_OPTIONS='--no-experimental-webstorage' next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
        "lint:fix": "eslint  . --ext .js,.jsx,.ts,.tsx --fix",
        "format": "prettier --write 'app/**/*.{js,jsx,ts,tsx,css}' 'app/styles/**/*.ts'",
