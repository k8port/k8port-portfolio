        "format:browns": "prettier --write 'app/styles/colors/neutrals/browns.ts'",
        "test:clear": "jest --clearCache",
        "test": "jest",
        "test:ci": "jest --ci --runInBand",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage"
